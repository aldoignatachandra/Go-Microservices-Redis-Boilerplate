#!/bin/bash
#
# Pre-commit hook for Go Microservices Redis PubSub Boilerplate
# Runs before every commit to ensure code quality
#

set -e

echo "🔍 Running pre-commit checks..."

# Get the list of staged Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    echo "✅ No Go files to check"
    exit 0
fi

# 1. Format code with gofmt
echo "📝 Formatting code with gofmt..."
gofmt -w $STAGED_GO_FILES
git add $STAGED_GO_FILES

# 2. Run go vet
echo "🔍 Running go vet..."
go vet ./...

# 3. Run golangci-lint (if installed)
if command -v golangci-lint &> /dev/null; then
    echo "🔬 Running golangci-lint..."
    golangci-lint run --timeout=5m ./...
else
    echo "⚠️  golangci-lint not installed, skipping lint check"
    echo "   Install with: go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
fi

# 4. Run tests (optional, uncomment if desired)
# echo "🧪 Running tests..."
# go test -short ./...

echo "✅ All pre-commit checks passed!"
